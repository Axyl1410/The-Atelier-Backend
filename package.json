{
  "name": "the-atelier-backend",
  "description": "The Atelier backend API",
  "dependencies": {
    "chanfana": "2.8.3",
    "hono": "4.11.1",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@cloudflare/vitest-pool-workers": "0.10.11",
    "@types/node": "24.10.1",
    "lefthook": "^2.1.4",
    "typescript": "5.9.3",
    "ultracite": "7.3.2",
    "vitest": "3.2.4",
    "wrangler": "4.56.0"
  },
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "schema": "npx chanfana",
    "test": "wrangler deploy --dry-run && npx vitest run --config tests/vitest.config.mts",
