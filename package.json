{
  "name": "TheAtelierTurbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:remote": "turbo run dev:remote",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "api-server:deploy": "turbo run deploy --filter=api-server",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "lefthook": "^2.1.4",
    "prettier": "^3.7.4",
    "turbo": "^2.8.21",
    "typescript": "5.9.2",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
