# You can find accountId, databaseId and token in Cloudflare dashboard.
# To get accountId go to Workers & Pages -> Overview -> copy Account ID from the right sidebar.
# To get databaseId open D1 database you want to connect to and copy Database ID.
# To get token go to My profile -> API Tokens and create token with D1 edit permissions.
# After you have configured drizzle.config.ts file, Drizzle Kit lets you run migrate, push, introspect and studio commands using Cloudflare D1 HTTP API.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
# Public URL of this Worker (no trailing slash). Used by Better Auth for callbacks and cookies.
BETTER_AUTH_URL=http://127.0.0.1:8787
# Generate a long random string; wrangler: npx wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=
RESEND_API_KEY=