{
  "name": "api-server",
  "description": "The Atelier backend API",
  "dependencies": {
    "better-auth": "^1.5.6",
    "chanfana": "2.8.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "4.11.1",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.10.11",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "5.9.3",
    "vitest": "3.2.4",
    "wrangler": "^4.78.0"
  },
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "schema": "npx chanfana",
    "test": "wrangler deploy --dry-run && npx vitest run --config tests/vitest.config.mts",
